{
    "options": {
        "toolbarTitle": "Horizontal Container"
    },
    "cameraConfig": {
        "captureResolution": "1080p",
        "pictureResolution": "1080p",
        "zoomGesture": true
    },
    "flashConfig": {
        "mode": "manual",
        "alignment": "top_right"
    },
    "viewPluginConfig": {
